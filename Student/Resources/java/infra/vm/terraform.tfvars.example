# Copy this file to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars to source control — it contains secrets.
# Your current public IP is detected automatically by Terraform.

prefix               = "wth"
location             = "swedencentral"
vm_size              = "Standard_D4s_v3"
admin_username       = "azureuser"
admin_password       = "CHANGEMEComplex1!"  # must be 12+ chars, upper+lower+digit+special, no underscores
resource_group_name  = "wth-photoalbum-vm-rg"

# ── Azure Database for PostgreSQL (Ora2Pg migration target) ───────────────────
db_admin_username    = "psqladmin"
db_admin_password    = "CHANGEMEPsql2!"     # must be 12+ chars, upper+lower+digit+special, no underscores
